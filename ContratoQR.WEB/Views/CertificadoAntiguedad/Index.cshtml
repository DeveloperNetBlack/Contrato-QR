@model FileExcelViewModel
@using GridMvc

@{
    ViewData["Title"] = "Contrato QR - Prestadores de Servicios Depto. Salud - Quilicura";
}
<div class="container">
    <div class="text-center">
        <h2 class="text-black py-5">
            Generar Certificados
        </h2>
    </div>
</div>

<div class="row" style="margin-top: 2rem; margin-bottom: 3rem;">
    @using (Html.BeginForm("GetPersonal", "CertificadoAntiguedad", FormMethod.Post))
    {
        <div class="row col-md-12">
            <div class="form-group col-md-3">
                <label for="txtRut">Rut</label>
                @Html.TextBoxFor(m => m.RutPersonal, new { @class = "form-control" })
            </div>
            <div class="form-group col-md-3">
                <label for="txtNombre">Nombre</label>
                @Html.TextBoxFor(m => m.NombrePersonal, new { @class = "form-control" })
            </div>
            <div class="form-group col-md-3">
                <label for="txtNombre">Tipo Funcionario</label>
                @Html.DropDownList("ddlTipoFuncionario", new SelectList(Model.ListaTipoFuncionario, "IdTipoFuncionario", "Descripcion"), "Seleccione un Tipo Funcionario", new { @class = "form-control" })
            </div>
            <div class="form-group col-md-1 d-flex justify-content-center">
                <button class="btn btn-info" type="submit">
                    Buscar
                </button>
            </div>
        </div>
    }
</div>
@await Html.Grid(Model.ListaPersonal).Columns(c =>
{
    c.Add(model => model.RutPersonal).Titled("Rut").SetWidth(150);
    c.Add(model => model.NombrePersonal).Titled("Nombre").SetWidth(350);
    c.Add()
    .Encoded(false)
    .Sanitized(false)
    .SetWidth(30)
    .RenderValueAs(o => $"<b><a class='modal_link' href='ListarPersonal?rutPersonal={o.RutPersonal}&idTipoFuncionario={o.IdTipoFuncionario}'>Ver</a></b>");
}).EmptyText("No se encontraron registros").RenderAsync()
